# Supabase — Public (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOURPROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase — Server only (NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Aadhaar Encryption — 32-byte key as 64-char hex string
# Generate: openssl rand -hex 32
AADHAAR_ENCRYPTION_KEY=replace_with_64_char_hex_string_generated_by_openssl
